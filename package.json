{
  "name": "fooconvert",
  "version": "1.2.8",
  "license": "GPL-3.0-or-later",
  "title": "FooConvert",
  "description": "Turning clicks into conversions, visitors into customers – the ultimate catalyst for online success!",
  "repository": "https://github.com/fooplugins/fooconvert",
  "bugs": "https://github.com/fooplugins/fooconvert/issues",
  "author": "FooPlugins <info@fooplugins.com>",
  "imports": {
    "#editor": "./src/editor/index.js",
    "#frontend": "./src/frontend/index.js",
    "#editor-pro": "./pro/src/editor/index.js",
    "#frontend-pro": "./pro/src/frontend/index.js"
  },
  "browserslist": [
    "defaults"
  ],
  "scripts": {
    "check-updates": "npx npm-check-updates",
    "test:php": "php tests/run.php",
    "build:dev": "cross-env BUILD_SCOPE=free NODE_ENV=development wp-scripts build --output-path=assets && npm run copy:free",
    "build": "cross-env BUILD_SCOPE=free wp-scripts build --output-path=assets && npm run copy:free",
    "build:pro": "cross-env BUILD_SCOPE=pro wp-scripts build --output-path=assets && npm run copy:pro",
    "start": "cross-env BUILD_SCOPE=free wp-scripts start --output-path=assets",
    "start:pro": "cross-env BUILD_SCOPE=pro wp-scripts start --output-path=assets",
    "develop": "cross-env BUILD_SCOPE=free wp-scripts start --no-watch --output-path=assets && npm run copy:free",
    "develop:pro": "cross-env BUILD_SCOPE=pro wp-scripts start --no-watch --output-path=assets && npm run copy:pro",
    "copy": "node copy-assets.mjs",
    "copy:free": "cross-env BUILD_SCOPE=free node copy-assets.mjs",
    "copy:pro": "cross-env BUILD_SCOPE=pro node copy-assets.mjs",
    "i18n": "node make-pot.mjs",
    "composer:install": "composer install --prefer-dist --optimize-autoloader --no-dev",
    "composer:update": "composer update --optimize-autoloader",
    "composer:refresh": "composer dump-autoload --optimize",
    "package:create-zip": "npm run build && npm run i18n && npm run composer:refresh && gulp",
    "package:deploy": "gulp freemius-deploy",
    "repomix": "repomix"
  },
  "devDependencies": {
    "@steveush/utils": "^0.0.2",
    "@woocommerce/dependency-extraction-webpack-plugin": "^3.1.0",
    "@wordpress/blob": "^4.40.0",
    "@wordpress/block-editor": "^15.13.1",
    "@wordpress/blocks": "^15.13.0",
    "@wordpress/components": "^32.2.0",
    "@wordpress/compose": "^7.40.0",
    "@wordpress/core-data": "^7.40.1",
    "@wordpress/data": "^10.40.0",
    "@wordpress/dependency-extraction-webpack-plugin": "^6.40.0",
    "@wordpress/dom": "^4.40.0",
    "@wordpress/dom-ready": "^4.40.0",
    "@wordpress/edit-post": "^8.40.1",
    "@wordpress/editor": "^14.40.1",
    "@wordpress/element": "^6.40.0",
    "@wordpress/hooks": "^4.40.0",
    "@wordpress/i18n": "^6.13.0",
    "@wordpress/icons": "^11.7.0",
    "@wordpress/notices": "^5.40.0",
    "@wordpress/plugins": "^7.40.0",
    "@wordpress/primitives": "^4.40.0",
    "@wordpress/scripts": "^31.5.0",
    "@wordpress/url": "^4.40.0",
    "chalk": "^5.6.2",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "fast-glob": "^3.3.3",
    "globby": "^16.1.1",
    "gulp": "^5.0.1",
    "gulp-freemius-deploy": "^1.0.11",
    "gulp-zip": "^6.1.0",
    "raw-loader": "^4.0.2",
    "repomix": "^1.12.0",
    "sharp": "^0.34.5"
  }
}
